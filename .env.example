# ============================================
# Sakura AI Environment Configuration File 
# ============================================
# Description: 
# - This file contains all configurations for application runtime 
# - For Docker image build configurations, please refer to: docker/Debian Linux/config.sh 
# - Copy this file to .env and modify the corresponding values 
# ============================================

# ========== Database Configuration ========== 
# Use the default Docker database, configure the root password and sakura_ai password (for Docker deployment) 
MYSQL_ROOT_PASSWORD=your_mysql_root_password_here
DB_PASSWORD=your_sakura_ai_db_password_here

# Use a specific database, can configure any MySQL database (for local development) 
DATABASE_URL=mysql://root:your_mysql_root_password_here@localhost:3306/sakura_ai
# DATABASE_URL=mysql://sakura_ai:your_sakura_ai_db_password_here@localhost:3306/sakura_ai
# DATABASE_URL=mysql://root:7PhaaEL3REbCabRb@172.19.5.222:3306/sakura_ai

# ========== Application Configuration ========== 
NODE_ENV=development               # Environment: development / production 
VITE_PORT=5173                     # Frontend port 
PORT=3001                          # Backend port 
SERVER_HOST=0.0.0.0                # Listen on all network interfaces (recommended) [cite: 1, 2]
# SERVER_HOST=127.0.0.1              # Local access only (security restriction) 

# Evidence service base URL (optional, leave blank to auto-fetch from request headers) 
# If a fixed URL is needed (e.g., reverse proxy scenario), set manually: http://your-domain.com 
# BASE_URL=

# ========== JWT Authentication ========== 
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRES_IN=7d                  # Token expiration time 

# ========== Playwright Configuration ========== 
PLAYWRIGHT_HEADLESS=true           # Headless mode: true / false 
PLAYWRIGHT_BROWSER=chromium        # Browser: chromium / firefox / webkit 

# ========== Test Execution Configuration ========== 
TEST_TIMEOUT=600000                # Test timeout: 10 minutes 
MAX_CONCURRENT_TESTS=6             # Maximum concurrent tests

# ========== MCP Browseronfiguration ========== 
MCP_BROWSER_FULLSCREEN=true        # MCP mode browser fullscreen: true / false (default: true) 
MCP_BROWSER_MAXIMIZED=true         # MCP mode browser maximized: true / false (default: true) 
MCP_BROWSER_WINDOW_SIZE=1920,1080  # MCP mode browser window size (default: 1920,1080)

# Phase 7: Browser pre-installation optimization - Set to false to skip pre-installation check and improve startup speed
PLAYWRIGHT_PRE_INSTALL_BROWSER=true

# AI Service Configuration (OpenRouter)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_MODEL=openai/gpt-4o
DEFAULT_TEMPERATURE=0.3
DEFAULT_MAX_TOKENS=4000

# Used for locally deployed Gemini 2.5 Flash model
GEMINI_LOCAL_BASE_URL=http://localhost:3000/v1
GEMINI_LOCAL_API_KEY=your_local_api_key_here

# Security Note: 
# - Replace GEMINI_LOCAL_API_KEY with the actual authentication key 
# - Use strong passwords in production environments, avoid default values (e.g., "123456") 
# - The .env file is excluded in .gitignore and will not be committed to version control 
# - Local API service must be started first (default port 3000) [cite: 3, 4]

# Proxy Configuration (Used for accessing external APIs) 
# HTTP_PROXY=http://127.0.0.1:10808
# HTTPS_PROXY=http://127.0.0.1:10808
HTTP_PROXY=
HTTPS_PROXY=

# ========== Qdrant Vector Database Knowledge Base Configuration ========== 
# http://172.19.5.227:6333/dashboard#/welcome
QDRANT_URL=http://172.19.5.227:6333

# Embedding provider 
EMBEDDING_PROVIDER=openai
EMBEDDING_API_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=your_openai_api_key_here
EMBEDDING_MODEL=text-embedding-3-small

# ========== Log Configuration ========== 
LOG_LEVEL=info                     # Log level: debug / info / warn / error 
LOG_FULL_PROMPT=false              # Whether to log the complete AI Prompt 
LOG_FILE_PATH=logs/ai.log
LOG_MAX_SIZE=50M
LOG_MAX_FILES=5