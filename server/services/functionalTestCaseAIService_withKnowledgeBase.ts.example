/**
 * 这是集成知识库后的 functionalTestCaseAIService.ts 示例代码
 *
 * 使用方法：
 * 1. 将此文件内容复制到 functionalTestCaseAIService.ts 的 generateBatch 方法中
 * 2. 在文件顶部添加 import
 * 3. 在构造函数中初始化 knowledgeBase
 */

// ============ Step 1: 在文件顶部添加 import ============
import { TestCaseKnowledgeBase } from './testCaseKnowledgeBase';

// ============ Step 2: 在类中添加属性 ============
export class FunctionalTestCaseAIService {
  private knowledgeBase: TestCaseKnowledgeBase;

  constructor() {
    // 原有的初始化代码...

    // 初始化知识库
    this.knowledgeBase = new TestCaseKnowledgeBase();
  }

  // ============ Step 3: 修改 generateBatch 方法 ============
  async generateBatch(
    batchId: string,
    scenarios: string[],
    requirementDoc: string,
    existingCases: TestCase[]
  ): Promise<TestCase[]> {
    const sectionId = scenarios[0];
    console.log(`🤖 开始生成批次 ${batchId}（章节 ${sectionId}）`);

    // 提取章节内容（保持原有逻辑）
    const sectionRegex = new RegExp(`###\\s+${sectionId.replace('.', '\\.')}\\s+(.+?)[\\s\\S]*?(?=###\\s+[\\d.]+\\s+|$)`);
    const sectionMatch = requirementDoc.match(sectionRegex);
    const sectionContent = sectionMatch ? sectionMatch[0] : requirementDoc.substring(0, 3000);
    const sectionName = sectionMatch ? sectionMatch[1].trim() : '功能模块';

    console.log(`📄 提取章节内容 - ${sectionId} ${sectionName} (${sectionContent.length}字符)`);

    // ============ 🔥 新增：从知识库检索相关知识 ============
    console.log('🔍 正在从知识库检索相关知识...');

    const knowledgeResults = await this.knowledgeBase.searchByCategory({
      query: sectionContent,
      businessDomain: this.projectInfo?.businessDomain,  // 使用项目业务领域
      topK: 2  // 每类知识取Top 2，控制token消耗
    });

    // 构建知识增强的Prompt
    const knowledgePrompt = this.buildKnowledgePrompt(knowledgeResults);
    console.log(`✅ 检索到知识: 业务规则${knowledgeResults.businessRules.length}条, 测试模式${knowledgeResults.testPatterns.length}条, 踩坑点${knowledgeResults.pitfalls.length}条, 资损场景${knowledgeResults.riskScenarios.length}条`);

    // ============ 原有的 systemPrompt（保持不变）============
    const systemPrompt = `你是一个测试用例设计专家。你的职责是：
1. 根据需求文档的指定章节生成详细的功能测试用例
2. 每个测试用例包含一个测试目的，以及若干个测试点
3. 每个测试点是一个独立的、可验证的测试项
4. 根据需求复杂度决定生成的测试点数量，不要人为限制数量
5. 避免与已存在的测试用例重复

🎯 数据结构：
- 一条测试用例 = 一个测试目的 + 多个测试点
- 测试目的：总体测试目标（如"验证订单创建流程"）
- 测试点：具体的测试项（如"正常提交订单"、"库存不足时提交订单"、"超时订单处理"）

📊 测试用例生成规则：
1. 数量不限制：根据需求文档的复杂度自动判断需要多少个测试点
2. 每个测试点必须是原子性的、独立验证的
3. 测试点应覆盖正常流程、异常流程、边界条件
4. 测试点应标注风险等级（low/medium/high）

测试用例结构要求：（保持原有格式）
...
`;

    const existingCaseNames = existingCases.map(tc => tc.name).join('\n- ');

    // ============ 🔥 修改：在 userPrompt 中注入知识库内容 ============
    const userPrompt = `请为以下需求文档章节生成详细的功能测试用例：

## 目标章节
章节ID: ${sectionId}
章节名称: ${sectionName}

## 章节需求内容
${sectionContent}

${knowledgePrompt}  // 🔥 注入知识库内容

## 已存在的测试用例（避免重复）
${existingCaseNames || '无'}

## 生成要求
1. 根据需求复杂度决定测试点数量，不要人为限制
2. 每个测试点必须独立且可验证
3. 覆盖正常流程、异常流程、边界条件
4. 特别关注上述业务规则、踩坑点和资损场景
5. 标注每个测试点的风险等级
6. 测试用例名称格式：[章节ID]-[测试目的]

请输出JSON格式：
（保持原有格式）
...
`;

    // 其余代码保持不变...
    try {
      const aiResponse = await this.callAI(systemPrompt, userPrompt, 8000);
      // ... 解析和返回逻辑
    } catch (error) {
      // ... 错误处理
    }
  }

  // ============ 🔥 新增方法：构建知识增强Prompt ============
  private buildKnowledgePrompt(knowledgeResults: {
    businessRules: any[];
    testPatterns: any[];
    pitfalls: any[];
    riskScenarios: any[];
  }): string {
    let prompt = '\n## 📚 相关知识参考（来自知识库）\n\n';

    // 业务规则
    if (knowledgeResults.businessRules.length > 0) {
      prompt += '### 💼 业务规则\n';
      knowledgeResults.businessRules.forEach(rule => {
        prompt += `**${rule.knowledge.title}**（相似度${(rule.score * 100).toFixed(0)}%）\n`;
        prompt += `${rule.knowledge.content}\n\n`;
      });
    }

    // 测试模式
    if (knowledgeResults.testPatterns.length > 0) {
      prompt += '### 📋 测试场景模式\n';
      knowledgeResults.testPatterns.forEach(pattern => {
        prompt += `**${pattern.knowledge.title}**\n`;
        prompt += `${pattern.knowledge.content}\n\n`;
      });
    }

    // 踩坑点
    if (knowledgeResults.pitfalls.length > 0) {
      prompt += '### ⚠️ 历史踩坑点（必须覆盖）\n';
      knowledgeResults.pitfalls.forEach(pitfall => {
        prompt += `**${pitfall.knowledge.title}**\n`;
        prompt += `${pitfall.knowledge.content}\n\n`;
      });
    }

    // 资损场景
    if (knowledgeResults.riskScenarios.length > 0) {
      prompt += '### 🔥 资损场景（高优先级）\n';
      knowledgeResults.riskScenarios.forEach(risk => {
        prompt += `**${risk.knowledge.title}**\n`;
        prompt += `${risk.knowledge.content}\n\n`;
      });
    }

    if (prompt === '\n## 📚 相关知识参考（来自知识库）\n\n') {
      return '';  // 如果没有检索到任何知识，返回空字符串
    }

    prompt += '**请参考以上知识，确保生成的测试用例覆盖相关业务规则、测试场景、踩坑点和资损场景。**\n';

    return prompt;
  }
}
