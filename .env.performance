# Performance Optimization Configuration File 
# Copy these configurations to the .env file to accelerate test execution 

# 1. Playwright Performance Optimization 
PLAYWRIGHT_HEADLESS=true                    # Headless mode is faster 
PLAYWRIGHT_DISABLE_IMAGES=true              # Disable image loading (improves speed) 
PLAYWRIGHT_DISABLE_CSS=false                # Retain CSS (affects element positioning) 
PLAYWRIGHT_TIMEOUT=10000                    # Global timeout 10 seconds 
PLAYWRIGHT_NAV_TIMEOUT=15000                # Page navigation timeout 15 seconds 

# 2. Test Execution Optimization 
PERFORMANCE_MODE=fast                       # Performance mode: fast | balanced | stable 
ENABLE_PERFORMANCE_MONITORING=true          # Enable performance monitoring 
MAX_CONCURRENCY=3                           # Maximum concurrent tests (increase with caution) 
TASK_TIMEOUT=180000                         # Task timeout 3 minutes 

# 3. Element Wait Time Optimization (reduce unnecessary waiting) 
DEFAULT_WAIT_TIMEOUT=2000                   # Default wait 2 seconds (originally 3 seconds) 
ELEMENT_VISIBLE_TIMEOUT=3000                # Element visible wait 3 seconds (originally 5 seconds) 
NEW_TAB_DETECT_TIMEOUT=800                  # New tab detection 800ms (originally 1200ms) [cite: 8]

# 4. AI Model Optimization [cite: 8]
AI_MODEL_PROVIDER=anthropic                 # Use a faster model [cite: 8]
AI_MODEL_NAME=claude-3-5-sonnet-20241022    # Or use haiku (faster but slightly lower accuracy) [cite: 8]
AI_MAX_TOKENS=2000                          # Limit response length to accelerate [cite: 8]

# 5. Log Optimization [cite: 8]
LOG_LEVEL=warn                              # Reduce log output to improve performance [cite: 8, 9]
ENABLE_STEP_SCREENSHOTS=false               # Disable per-step screenshots (only screenshot on failure) 
ENABLE_VIDEO_RECORDING=false                # Disable video recording 

# 6. Database Optimization 
DATABASE_CONNECTION_LIMIT=20                # Increase connection pool 
ENABLE_QUERY_LOGGING=false                  # Disable query logging 

# Suggested configuration combinations: 
# - Fast mode: PERFORMANCE_MODE=fast + PLAYWRIGHT_DISABLE_IMAGES=true + DEFAULT_WAIT_TIMEOUT=1500 
# - Balanced mode: PERFORMANCE_MODE=balanced (current default) 
# - Stable mode: PERFORMANCE_MODE=stable + double all timeouts 